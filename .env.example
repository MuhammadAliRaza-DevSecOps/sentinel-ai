# ============================================
# sentinel-ai — DevSecOps Pipeline
# ============================================
# HOW TO USE:
# 1. cp .env.example .env
# 2. .env mein apni real values daalo
# 3. .env KABHI GitHub pe push mat karo
# ============================================

# ── DATABASE ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@localhost:5432/devsecops_db
DB_PASSWORD=YOUR_DB_PASSWORD

# ── REDIS ─────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ── OLLAMA LOCAL AI ───────────────────────
# Install: https://ollama.ai
# Model:   ollama pull phi3:mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# ── EMAIL (Gmail SMTP) ────────────────────
# Gmail App Password:
# Google Account > Security > 2FA > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFY_EMAILS=your_email@gmail.com

# ── GITHUB ────────────────────────────────
# Token: github.com/settings/tokens
# Scopes: repo, workflow, write:packages
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your_github_username
GITHUB_REPO=sentinel-ai

# ── SECRET KEY ────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_generated_secret_key_here

# ── SCANNER SETTINGS ──────────────────────
MAX_SCAN_TIMEOUT_SECONDS=300
CRITICAL_FAIL_THRESHOLD=1
HIGH_FAIL_THRESHOLD=5

# ── APP SETTINGS ──────────────────────────
DEBUG=false
LOG_LEVEL=INFO
API_PORT=8000
DASHBOARD_PORT=8501